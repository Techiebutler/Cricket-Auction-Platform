# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=supersecretkey-change-in-production
GODMODE_SECRET=GODMODE_CHANGEME

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://auction:auction@db:5432/auction

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AWS SES (Email) ──────────────────────────────────────────────────────────
AWS_MAIL_ACCESS_KEY_ID=your-iam-access-key-id
AWS_MAIL_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_REGION=ap-south-1
EMAIL_FROM=auction@techiebutlermail.com

# ── AWS S3 (profile photos) ───────────────────────────────────────────────────
# If not set, falls back to AWS_MAIL_* keys when S3 is used
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_BUCKET_NAME=your-bucket-name

