# ══════════════════════════════════════════════════════════════════════════════
# Cricket Auction Platform - Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# For production, copy to .env.prod
# ══════════════════════════════════════════════════════════════════════════════

# ── App Secrets ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=supersecretkey-change-in-production
GODMODE_SECRET=GODMODE_CHANGEME

# ── Database ─────────────────────────────────────────────────────────────────
# Option 1: Use Docker's PostgreSQL (default for docker compose)
DATABASE_URL=postgresql+asyncpg://auction:auction@db:5432/auction

# Option 2: Use your own PostgreSQL (uncomment and modify)
# DATABASE_URL=postgresql+asyncpg://user:password@your-host:5432/your_database

# Option 3: Use cloud PostgreSQL (AWS RDS, Supabase, Neon, etc.)
# DATABASE_URL=postgresql+asyncpg://user:password@your-rds-endpoint.amazonaws.com:5432/auction

# ── Redis ────────────────────────────────────────────────────────────────────
# Option 1: Use Docker's Redis (default for docker compose)
REDIS_URL=redis://redis:6379

# Option 2: Use your own Redis (uncomment and modify)
# REDIS_URL=redis://your-redis-host:6379

# Option 3: Use cloud Redis (AWS ElastiCache, Upstash, etc.)
# REDIS_URL=redis://user:password@your-redis-endpoint:6379

# ── Frontend URLs ────────────────────────────────────────────────────────────
# Development defaults (change for production)
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api/auction/ws

# Production example:
# NEXT_PUBLIC_API_URL=https://auction.yourdomain.com/api
# NEXT_PUBLIC_WS_URL=wss://auction.yourdomain.com/api/auction/ws

# ── AWS SES (Email) - OPTIONAL ───────────────────────────────────────────────
# Leave empty to disable email features (invitations won't be sent)
# You can still manually share login links with users
AWS_MAIL_ACCESS_KEY_ID=
AWS_MAIL_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
EMAIL_FROM=auction@yourdomain.com

# ── AWS S3 (Profile Photos) - OPTIONAL ───────────────────────────────────────
# Leave empty to use local file storage (uploads/ directory)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ── Production Only (docker-compose.prod.yml) ────────────────────────────────
# REQUIRED for production - your domain for Traefik SSL certificates
PUBLIC_DOMAIN=auction.yourdomain.com
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# PostgreSQL credentials (defaults work for Docker, change for security)
POSTGRES_USER=auction
POSTGRES_PASSWORD=strong-password-here
POSTGRES_DB=auction

